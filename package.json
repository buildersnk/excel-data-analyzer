{
  "name": "excel-data-analyzer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n app,docs -c cyan,magenta \"npm:dev:app\" \"npm:dev:docs\"",
    "dev:app": "vite",
    "dev:docs": "npm --prefix docs-site start -- --port 3000",
    "build": "tsc -b && vite build",
    "build:docs": "npm --prefix docs-site run build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "alasql": "^4.17.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "reactflow": "^11.11.4",
    "recharts": "^3.8.1",
    "sql.js": "^1.14.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10"
  }
}
